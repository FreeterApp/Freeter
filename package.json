{
  "name": "freeter",
  "version": "2.8.0-beta",
  "main": "main.js",
  "homepage": "https://freeter.io/",
  "repository": "https://github.com/FreeterApp/Freeter.git",
  "author": "Alex Kaul",
  "license": "GPL-3.0-or-later",
  "description": "Organizer For Those Who Do",
  "scripts": {
    "dev": "cross-env REACT_DEVTOOLS=enabled npm run dev:react-devtools",
    "dev:react-devtools": "concurrently \"react-devtools\" \"npm run dev:no-react-devtools\"",
    "dev:no-react-devtools": "rimraf build && npm run dev:assets && npm run dev:preload && concurrently --names \"RENDERER,MAIN,RUN\" -c \"blue.bold,magenta.bold,green.bold\" \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:run\"",
    "dev:assets": "copyfiles --up 1 src/assets/**/* build/",
    "dev:preload": "cross-env NODE_ENV=development webpack --config webpack.preload.config.js",
    "dev:renderer": "cross-env NODE_ENV=development webpack-dev-server --config webpack.renderer.config.js",
    "dev:main": "cross-env NODE_ENV=development webpack --watch --config webpack.main.config.js",
    "dev:run": "cross-env NODE_ENV=development nodemon --on-change-only --watch build/main.js --exec \"sleep 3 && electron ./build/main.js\"",
    "prod": "rimraf build && npm run prod:assets && concurrently --names \"RENDERER,MAIN,PRELOAD\" -c \"blue.bold,magenta.bold,green.bold\" \"npm run prod:renderer\" \"npm run prod:main\" \"npm run prod:preload\"",
    "prod:assets": "copyfiles --up 1 src/assets/**/* build/",
    "prod:preload": "cross-env NODE_ENV=production webpack --config webpack.preload.config.js",
    "prod:renderer": "cross-env NODE_ENV=production webpack --config webpack.renderer.config.js",
    "prod:main": "cross-env NODE_ENV=production webpack --config webpack.main.config.js",
    "prod:run": "electron ./build/main.js",
    "package": "electron-builder --config electron-builder.config.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --clearCache && cross-env JEST_HIDE_USAGE=1 jest --watch",
    "test:typecheck:common": "tsc --project ./tests/common/tsconfig.json --noEmit",
    "test:typecheck:main": "tsc --project ./tests/main/tsconfig.json --noEmit",
    "test:typecheck:renderer": "tsc --project ./tests/renderer/tsconfig.json --noEmit",
    "test:typecheck": "concurrently --names \"RENDERER,MAIN,COMMON\" -c \"blue.bold,magenta.bold,green.bold\" \"npm run test:typecheck:renderer\" \"npm run test:typecheck:main\" \"npm run test:typecheck:common\"",
    "lint": "concurrently \"npm run lint:common\" \"npm run lint:main\" \"npm run lint:renderer\" \"npm run lint:tests:common\" \"npm run lint:tests:main\" \"npm run lint:tests:renderer\" \"npm run lint:tests:utils\"",
    "lint:common": "cd src && cd common && eslint \"**/*.{ts,tsx}\"",
    "lint:common:fix": "cd src && cd common && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:main": "cd src && cd main && eslint \"**/*.{ts,tsx}\"",
    "lint:main:fix": "cd src && cd main && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:renderer": "cd src && cd renderer && eslint \"**/*.{ts,tsx}\"",
    "lint:renderer:fix": "cd src && cd renderer && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:tests:common": "cd tests && cd common && eslint \"**/*.{ts,tsx}\"",
    "lint:tests:common:fix": "cd tests && cd common && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:tests:main": "cd tests && cd main && eslint \"**/*.{ts,tsx}\"",
    "lint:tests:main:fix": "cd tests && cd main && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:tests:renderer": "cd tests && cd renderer && eslint \"**/*.{ts,tsx}\"",
    "lint:tests:renderer:fix": "cd tests && cd renderer && eslint \"**/*.{ts,tsx}\" --fix",
    "lint:tests:utils": "cd tests && cd utils && eslint \"**/*.{ts,tsx}\"",
    "lint:tests:utils:fix": "cd tests && cd utils && eslint \"**/*.{ts,tsx}\" --fix",
    "cd:package-draft": "npm run package",
    "draft-release": "read -p 'Enter version: ' ver && npm version $ver && git push && git push --tags"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.1.14",
    "react": "^19.2.6",
    "react-devtools": "^7.0.1",
    "react-dom": "^19.2.6",
    "rimraf": "^6.1.3",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "svg-sprite-loader": "^6.0.11",
    "svgo-loader": "^5.0.0",
    "swc-loader": "^0.2.7",
    "tiny-markdown-editor": "^0.2.28",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "use-sync-external-store": "^1.6.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  }
}
